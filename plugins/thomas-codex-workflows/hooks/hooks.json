{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/bin/bash \"${CLAUDE_PLUGIN_ROOT}/hooks/repo-safety.sh\"",
            "statusMessage": "Checking repo safety"
          }
        ]
      }
    ],
    "WorktreeCreate": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/bin/bash \"${CLAUDE_PLUGIN_ROOT}/hooks/worktree-create.sh\"",
            "statusMessage": "Preparing new worktree"
          }
        ]
      }
    ]
  }
}
