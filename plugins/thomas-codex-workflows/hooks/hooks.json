{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/bin/bash \"${CLAUDE_PLUGIN_ROOT}/hooks/repo-safety.sh\"",
            "statusMessage": "Checking repo safety"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/bin/bash \"${CLAUDE_PLUGIN_ROOT}/hooks/warp-cwd-osc7.sh\"",
            "timeout": 2000
          }
        ]
      }
    ],
    "WorktreeCreate": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/bin/bash \"${CLAUDE_PLUGIN_ROOT}/hooks/worktree-create.sh\"",
            "statusMessage": "Preparing new worktree"
          }
        ]
      }
    ],
    "WorktreeRemove": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/bin/bash \"${CLAUDE_PLUGIN_ROOT}/hooks/worktree-remove.sh\"",
            "statusMessage": "Cleaning worktree metadata"
          }
        ]
      }
    ]
  }
}
